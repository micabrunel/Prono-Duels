# --- Configuration de l'envoi du récap par email ---
# Copie ce fichier en ".env" pour le développement local (npm start).
# En production sur Cloudflare Pages, ces valeurs se mettent dans
# le dashboard (Settings → Environment variables), PAS dans ce fichier.
#
# Si rien n'est configuré, le jeu fonctionne quand même : il propose
# un lien "Envoyer manuellement" (mailto) à la fin.

# Adresse qui reçoit le récap (par défaut : brunel.michael@gmail.com)
RECIPIENT_EMAIL=brunel.michael@gmail.com

# === Méthode recommandée (locale ET Cloudflare) : Resend ===
# 1. Crée un compte gratuit sur https://resend.com
# 2. Génère une clé API et colle-la ici.
# 3. (Optionnel) Vérifie un domaine pour personnaliser l'expéditeur.
#    Sans domaine vérifié, utilise l'expéditeur de test "onboarding@resend.dev".
RESEND_API_KEY=
MAIL_FROM=Duo Délice <onboarding@resend.dev>

# === Alternative pour le dev local uniquement : SMTP (Gmail) ===
# Ignoré en prod Cloudflare (pas de SMTP sur Workers). À ne remplir que
# si tu préfères Gmail en local plutôt que Resend.
#   1. Active la validation en 2 étapes sur ton compte Google
#   2. Crée un "mot de passe d'application" : https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Port du serveur web local (optionnel)
PORT=3000
