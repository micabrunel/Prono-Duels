# --- Configuration de l'envoi du récap par email ---
# Copie ce fichier en ".env" et remplis les valeurs.
# Si tu ne configures rien, le jeu fonctionne quand même :
# il proposera un lien "Envoyer manuellement" à la fin.

# Adresse qui reçoit le récap (par défaut : brunel.michael@gmail.com)
RECIPIENT_EMAIL=brunel.michael@gmail.com

# Serveur SMTP. Exemple pour Gmail :
#   1. Active la validation en 2 étapes sur ton compte Google
#   2. Crée un "mot de passe d'application" : https://myaccount.google.com/apppasswords
#   3. Mets ce mot de passe (16 caractères) dans SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ton.adresse@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx

# Expéditeur affiché
MAIL_FROM=Prono-Duels <ton.adresse@gmail.com>

# Port du serveur web (optionnel)
PORT=3000
